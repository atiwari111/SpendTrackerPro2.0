<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SpendTrackerPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_main</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_nav</item>
        <item name="android:windowLightStatusBar">true</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Inter as global app font — clean neo-banking look -->
        <item name="android:fontFamily">@font/inter</item>

        <item name="android:colorControlHighlight">#337C3AED</item>
        <item name="rippleColor">#337C3AED</item>
        <item name="bottomNavigationStyle">@style/BottomNavStyle</item>
    </style>

    <style name="Theme.SpendTrackerPro.Splash" parent="Theme.SpendTrackerPro">
        <item name="android:windowBackground">@color/bg_dark</item>
    </style>

    <!-- Neo-Banking alert dialog -->
    <style name="AlertDialogDark" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorPrimary">@color/purple_main</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:background">@color/bg_card</item>
        <item name="android:colorBackground">@color/bg_card</item>
    </style>

    <style name="DialogTitleText" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Neo-Banking bottom nav — no background tint, clean dark bar -->
    <style name="BottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/bg_nav</item>
        <item name="itemIconTint">@color/bottom_nav_tint</item>
        <item name="itemTextColor">@color/bottom_nav_tint</item>
        <item name="itemRippleColor">#337C3AED</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Toolbar — transparent to let page background show -->
    <style name="ToolbarStyle" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/bg_dark</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="navigationIconTint">@color/text_primary</item>
    </style>

</resources>
