<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_card" app:titleTextColor="@color/text_primary"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- ══ SECURITY ══ -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SECURITY" android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/purple_main" android:letterSpacing="0.1"
                android:layout_marginTop="4dp" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Biometric Lock" android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Require fingerprint to open app"
                            android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat android:id="@+id/swBiometric" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:thumbTint="@color/purple_main"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ APPEARANCE ══ -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="APPEARANCE" android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/purple_main" android:letterSpacing="0.1"
                android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Dark Theme" android:textColor="@color/text_primary" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Use dark mode across the app"
                            android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <RadioGroup
                        android:id="@+id/rgTheme"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <RadioButton
                            android:id="@+id/rbThemeLight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Light"
                            android:textColor="@color/text_primary"/>
                        <RadioButton
                            android:id="@+id/rbThemeDark"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Dark"
                            android:textColor="@color/text_primary"/>
                    </RadioGroup>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

    <!-- ══ NOTIFICATIONS ══ -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NOTIFICATIONS" android:textSize="11sp" android:textStyle="bold"
        android:textColor="@color/purple_main" android:letterSpacing="0.1"
        android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

    <!-- Daily Spend Summary Notification -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/bg_card" android:layout_marginBottom="8dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊 Daily Spend Summary"
                android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/text_primary"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Get a smart spending summary at 8 PM daily"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <androidx.appcompat.widget.SwitchCompat android:id="@+id/swDailySummary"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:checked="true"
            android:thumbTint="@color/purple_main"
            android:trackTint="@color/purple_dim"/>
    </LinearLayout>

            <!-- ══ DATA ══ -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DATA" android:textSize="11sp" android:textStyle="bold"
                android:textColor="@color/purple_main" android:letterSpacing="0.1"
                android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="8dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="4dp">

                    <Button android:id="@+id/btnExportCsv"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:text="📤  Export as CSV" android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#22FFFFFF" android:layout_marginStart="16dp"/>

                    <Button android:id="@+id/btnCsvImport"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:text="📥  Import from CSV" android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#22FFFFFF" android:layout_marginStart="16dp"/>

                    <Button android:id="@+id/btnRecurring"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:text="🔁  Recurring Bills" android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#22FFFFFF" android:layout_marginStart="16dp"/>

                    <Button android:id="@+id/btnNetWorth"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:text="📊  Net Worth Tracker" android:backgroundTint="@android:color/transparent"
                        android:textColor="@color/text_primary" android:textSize="14sp" android:gravity="start|center_vertical"
                        android:paddingStart="16dp"/>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ══ CLEAR DATA ══ -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚠ Clear Data" android:textSize="11sp" android:textStyle="bold"
                android:textColor="#EF4444" android:letterSpacing="0.1"
                android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>

            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1AEF4444" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="This permanently deletes local transactions only. Your budgets, cards, accounts and cloud backup remain unchanged."
                        android:textColor="@color/text_secondary" android:textSize="12sp" android:layout_marginBottom="12dp"/>
                    <Button android:id="@+id/btnClearData"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:text="Delete Local Transactions"
                        android:backgroundTint="#EF4444" android:textColor="@color/text_primary"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- P4: Backup & Restore -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔒 Backup &amp; Restore"
                        android:textSize="14sp" android:textStyle="bold"
                        android:textColor="@color/text_primary" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Encrypted with AES-256-GCM · Bound to this device"
                        android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp"/>
                    <Button android:id="@+id/btnBackup"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:text="📤  Create Backup"
                        android:backgroundTint="@color/purple_main" android:textColor="@color/text_primary"
                        android:textSize="13sp" android:layout_marginBottom="8dp"/>
                    <Button android:id="@+id/btnRestore"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:text="📥  Restore from Backup"
                        android:backgroundTint="@color/bg_card" android:textColor="@color/text_primary"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- App version -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:id="@+id/tvAppInfo" android:text="SpendTracker Pro v2.0\nBuilt with 🔒 AES-256 encryption"
                android:textColor="@color/text_secondary" android:textSize="11sp"
                android:gravity="center" android:layout_marginBottom="16dp" android:lineSpacingExtra="4dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
