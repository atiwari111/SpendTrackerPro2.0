# Local gradle overrides (put your keystore passwords here locally)
local.gradle.properties
# NOTE: You must also run these two commands once to un-track already-committed files:
#   git rm --cached app/spendtracker.keystore
#   git rm --cached app/google-services.json

# ── Gradle Wrapper JAR — MUST be committed for CI to work ────
# Force-include even if a parent rule would otherwise exclude it.
!gradle/wrapper/gradle-wrapper.jar
